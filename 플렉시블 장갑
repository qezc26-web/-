Serial.print("F: ");
Serial.print((int)filtered[0]); Serial.print(" ");
Serial.print((int)filtered[1]); Serial.print(" ");
Serial.print((int)filtered[2]); Serial.print(" ");
Serial.print((int)filtered[3]); Serial.print(" ");
Serial.print((int)filtered[4]);

Serial.print(" | IMU: ");
